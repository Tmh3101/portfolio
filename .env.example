APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_ORIGIN=http://localhost:3000,https://your-domain.com,https://*.vercel.app

# Supabase project (required for database)
SUPABASE_PROJECT_ID=your-project-ref
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend)
MAIL_FROM="portfolio <noreply@yourdomain.com>"
CONTACT_TO_EMAIL=hieutm.site@gmail.com
# RESEND_API_KEY=your-resend-api-key

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Public
NEXT_PUBLIC_SITE_URL=https://your-domain.com
# Leave empty to use same-origin API routes
NEXT_PUBLIC_API_BASE_URL=
